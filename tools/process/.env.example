# MongoDB used by tools/process
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/
DB_NAME=seevector
COLLECTION=dev

# Local Ollama models
LLAMA_VISION_IMAGE_MODEL=llama3.2-vision:11b
INSTRUCT_MODEL=mistral:7b-instruct

# Voyage AI document embeddings
VOYAGE_API_KEY=pa-your-key
VOYAGE_EMBED_MODEL=voyage-4
VOYAGE_EMBED_INPUT_TYPE=document
